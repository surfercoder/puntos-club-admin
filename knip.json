{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/{page,layout,template,loading,error,not-found,route}.{ts,tsx}",
    "app/**/{default,global-error,forbidden,unauthorized}.{ts,tsx}",
    "sentry.{edge,server,client}.config.ts",
    "e2e/**/*.setup.ts",
    "e2e/**/*.spec.ts",
    "scripts/**/*.ts",
    "__tests__/**/*.{ts,tsx}",
    "i18n/**/*.ts"
  ],
  "project": [
    "**/*.{ts,tsx}",
    "!node_modules/**",
    "!.next/**",
    "!playwright-report/**",
    "!coverage/**",
    "!types/supabase.ts"
  ],
  "ignore": [
    "components/ui/**"
  ],
  "ignoreDependencies": [
    "@fontsource/lexend",
    "@fontsource/poppins",
    "tw-animate-css",
    "shadcn",
    "babel-jest",
    "jsdom"
  ],
  "ignoreBinaries": [
    "dotenv",
    "dotenv-cli",
    "supabase"
  ],
  "ignoreExportsUsedInFile": true
}
